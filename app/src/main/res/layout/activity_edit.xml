<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    >

    <!-- Top AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_edit"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_container_lowest"
            app:title="추억 기록하기"
            app:titleTextColor="@color/on_surface"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/on_surface">
            
            <Button
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:text="저장"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                style="@style/Widget.Material3.Button" />
                
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Image preview card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/outline_variant"
                app:cardBackgroundColor="@color/surface_variant">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/iv_edit_photo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="기록 사진" />

                    <!-- Centered Photo select prompt -->
                    <LinearLayout
                        android:id="@+id/layout_add_photo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/primary"
                            android:contentDescription="카메라 아이콘" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="사진 추가하기"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- Photo option overlay buttons -->
                    <LinearLayout
                        android:id="@+id/layout_photo_options"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/btn_photo_camera"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text="촬영"
                            android:textSize="12sp"
                            android:backgroundTint="@color/white"
                            android:textColor="@color/primary"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/primary"
                            style="@style/Widget.Material3.Button.OutlinedButton" />

                        <Button
                            android:id="@+id/btn_photo_gallery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="갤러리"
                            android:textSize="12sp"
                            android:backgroundTint="@color/white"
                            android:textColor="@color/primary"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/primary"
                            style="@style/Widget.Material3.Button.OutlinedButton" />
                    </LinearLayout>

                    <!-- GPS extraction progress overlay -->
                    <LinearLayout
                        android:id="@+id/layout_gps_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_margin="12dp"
                        android:background="#80000000"
                        android:padding="6dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/white"
                            android:contentDescription="위치 아이콘" />

                        <TextView
                            android:id="@+id/tv_gps_info"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="GPS 추출 완료"
                            android:textColor="@color/white"
                            android:textSize="10sp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Input fields -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="여행지 이름"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/secondary"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_place_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="어디로 다녀오셨나요?"
                    android:inputType="text"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="방문 날짜"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_select_date"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="날짜 선택"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:backgroundTint="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/outline"
                app:icon="@drawable/ic_calendar"
                app:iconGravity="end"
                app:iconTint="@color/outline"
                style="@style/Widget.Material3.Button.ElevatedButton" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="여행의 추억 (메모)"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/secondary"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_memo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="5"
                    android:gravity="top"
                    android:hint="여행에서의 즐거웠던 기억을 남겨보세요..."
                    android:inputType="textMultiLine"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_latlong_display"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="GPS 위치 정보 없음"
                    android:textColor="@color/outline"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Async operations progress overlay -->
    <FrameLayout
        android:id="@+id/progress_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:background="@drawable/dialog_bg">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:id="@+id/tv_progress_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사진 처리 및 분석 중..."
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
