<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/googleMapContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/mapSearchContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/search_box_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_location" />

        <EditText
            android:id="@+id/mapSearchBox"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="장소 검색..."
            android:imeOptions="actionSearch"
            android:includeFontPadding="false"
            android:inputType="text"
            android:padding="0dp"
            android:singleLine="true"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/on_surface_variant"
            android:textSize="17sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/mapEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="24dp"
        android:text="GPS가 포함된 기록이 지도에 표시됩니다."
        android:textColor="@color/on_surface_variant"
        android:textSize="16sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/mapControlPanel"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="20dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/myLocationButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/map_control_background"
            android:contentDescription="현재 위치"
            android:elevation="6dp"
            android:padding="14dp"
            android:src="@drawable/ic_my_location" />

        <ImageButton
            android:id="@+id/zoomInButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/map_control_background"
            android:contentDescription="확대"
            android:elevation="6dp"
            android:padding="14dp"
            android:src="@drawable/ic_plus_dark" />

        <ImageButton
            android:id="@+id/zoomOutButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/map_control_background"
            android:contentDescription="축소"
            android:elevation="6dp"
            android:padding="14dp"
            android:src="@drawable/ic_minus_dark" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mapRecordCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="20dp"
        android:visibility="gone"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:id="@+id/mapCardImage"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:background="@color/surface_variant"
                android:contentDescription="여행 사진"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/mapCardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mapCardDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/mapCardMemo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/mapCardCloseButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="닫기"
                android:src="@drawable/ic_delete" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
