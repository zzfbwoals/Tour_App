<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/googleMapContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/mapSearchContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/search_box_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_location" />

        <EditText
            android:id="@+id/mapSearchBox"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="장소 검색..."
            android:imeOptions="actionSearch"
            android:includeFontPadding="false"
            android:inputType="text"
            android:padding="0dp"
            android:singleLine="true"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/on_surface_variant"
            android:textSize="17sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/mapSuggestionList"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="90dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/search_box_background"
        android:elevation="8dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/mapEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="24dp"
        android:text="GPS가 포함된 기록을 지도에 표시합니다."
        android:textColor="@color/on_surface_variant"
        android:textSize="16sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/mapControlPanel"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="20dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/myLocationButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/map_control_background"
            android:contentDescription="현재 위치"
            android:elevation="6dp"
            android:padding="14dp"
            android:src="@drawable/ic_my_location" />

        <ImageButton
            android:id="@+id/zoomInButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/map_control_background"
            android:contentDescription="확대"
            android:elevation="6dp"
            android:padding="14dp"
            android:src="@drawable/ic_plus_dark" />

        <ImageButton
            android:id="@+id/zoomOutButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/map_control_background"
            android:contentDescription="축소"
            android:elevation="6dp"
            android:padding="14dp"
            android:src="@drawable/ic_minus_dark" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/mapRecordPager"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="20dp"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/mapCardIndicator"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone" />
</FrameLayout>
